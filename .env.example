# MariaDB 접속 정보
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=oci_crm

# Docker Compose 전용 (docker-compose.yml 사용 시)
DB_ROOT_PASSWORD=your_root_password

# 서버 포트
PORT=3000

# Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
# AI 어시스턴트, 명함 OCR, 회의록 STT/요약 기능에 사용됩니다.
GEMINI_API_KEY=your_gemini_api_key

# JWT 시크릿 (반드시 변경하세요)
JWT_SECRET=oci-crm-jwt-secret-change-me

# CORS 허용 Origin 목록 (쉼표 구분, 프로덕션에서 반드시 설정)
# 예) ALLOWED_ORIGINS=https://crm.example.com,https://app.example.com
# 미설정 시 모든 Origin 허용 (개발 환경 전용)
ALLOWED_ORIGINS=

# ── 전자서명 (모두싸인) — v6.0.0 Step 4 ─────────────────────
# 모두싸인 개발자 콘솔 (https://developers.modusign.co.kr) 에서 OAuth 클라이언트 발급
# 키 미설정 시 자동으로 Mock 모드 (개발/테스트 환경 — 실제 외부 호출 없음)
MODUSIGN_CLIENT_ID=your-modusign-oauth-client-id
MODUSIGN_CLIENT_SECRET=your-modusign-oauth-client-secret
# API/OAuth Base URL (대부분 변경 불필요)
MODUSIGN_API_BASE_URL=https://api.modusign.co.kr
MODUSIGN_OAUTH_BASE_URL=https://app.modusign.co.kr
# 운영: https://oci-crm.duckdns.org/api/contracts/esign/oauth/callback
MODUSIGN_REDIRECT_URI=http://localhost:3001/api/contracts/esign/oauth/callback
# Webhook 서명 검증용 (모두싸인 관리자 → 설정 → API → Webhook 에서 발급)
MODUSIGN_WEBHOOK_SECRET=your-modusign-webhook-secret
# 토글 — 0 = OAuth 모드 (권장) / 1 = API Key 모드 (단일 계정용, 간소화)
MODUSIGN_USE_API_KEY=0
MODUSIGN_API_KEY=
# 암호화 키 (Google OAuth 와 공유) — 64 hex chars (32 bytes)
# 미설정 시 자동 생성된 임시 키 사용 (재시작 시 토큰 무효화됨 — 운영 환경에서 반드시 설정)
ENCRYPTION_KEY=
