{
  "name": "oci-crm",
  "version": "1.0.0",
  "description": "OCI CRM - 핑거세일즈 기반 태양광 영업 관리 시스템",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky || echo 'husky skipped (production or unavailable)'",
    "init-db": "node scripts/init-db.js",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "cap:build:android": "cd android && ./gradlew assembleDebug",
    "cap:doctor": "npx cap doctor"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "server.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "public/js/**/*.js": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "eslint": "^10.3.0",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "globals": "^17.6.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "otplib": "^13.4.0",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^1.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^1.6.1"
  },
  "author": "OCI",
  "license": "MIT"
}
